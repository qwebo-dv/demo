# Nuxt public site
NUXT_PUBLIC_SITE_URL=https://archterra.ru

# Strapi CMS integration. Leave empty to use bundled fallback content during local prototyping.
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=

# Strapi backend
HOST=0.0.0.0
PORT=1337
APP_KEYS=replace-me-1,replace-me-2,replace-me-3,replace-me-4
API_TOKEN_SALT=replace-me-token-salt
ADMIN_JWT_SECRET=replace-me-admin-jwt-secret
TRANSFER_TOKEN_SALT=replace-me-transfer-token-salt
JWT_SECRET=replace-me-jwt-secret
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
